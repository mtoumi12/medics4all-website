# ============================================================================
# Medics4ALL Core Scribe — example environment file
# Copy to `.env` and pick a profile (or mix-and-match providers).
# ============================================================================

# --- Application ---
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# --- Storage (SQLite for dev, swap for Postgres in prod) ---
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/medics4all
DATABASE_URL=sqlite:///./medics4all.db


# ============================================================================
# PROFILE A — CLOUD  (paid, fastest, requires OpenAI key)
# ----------------------------------------------------------------------------
# Cost: ~$0.10 per 15-min visit
# Privacy: data leaves your machine; needs Azure OpenAI + signed BAA before PHI
# ============================================================================
ASR_PROVIDER=openai
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
WHISPER_MODEL=whisper-1
LLM_MODEL=gpt-4o-mini


# ============================================================================
# PROFILE B — LOCAL  (free, private, fully offline)
# ----------------------------------------------------------------------------
# Cost: $0 per visit (uses your CPU/GPU)
# Privacy: NOTHING leaves the laptop — fine for demos with real PHI
# Setup:
#   1. Make sure Ollama is running:  open -a Ollama   (or `ollama serve`)
#   2. Pull a model:  ollama pull llama3.1:8b
#   3. The first /audio request downloads faster-whisper "base.en" (~150 MB).
#
# To use this profile, uncomment the four LOCAL_* lines below and comment out
# the cloud OPENAI_API_KEY/PROVIDER lines above.
# ----------------------------------------------------------------------------
# ASR_PROVIDER=local
# LLM_PROVIDER=ollama
# LOCAL_WHISPER_MODEL=base.en           # tiny.en (39M) | base.en (74M) | small.en (244M) | medium.en (769M) | large-v3 (1.5B)
# LOCAL_WHISPER_DEVICE=auto             # auto | cpu | cuda
# LOCAL_WHISPER_COMPUTE_TYPE=int8       # int8 (low memory) | float16 (GPU)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b              # llama3.1:8b | llama3.1:70b | llama3.2 | qwen2.5:14b


# ============================================================================
# PROFILE C — HYBRID  (local ASR + cloud LLM, or vice versa)
# ----------------------------------------------------------------------------
# Common pattern: keep audio (PHI-rich) on-device, use cloud for the cheap
# text-based summarization. Reduces PHI exposure while keeping note quality.
#
# Example:
#   ASR_PROVIDER=local
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
# ============================================================================


# --- (Future) Deepgram, Azure OpenAI ---
DEEPGRAM_API_KEY=

# --- Security (placeholder; wire real auth before any pilot) ---
DEV_API_KEY=dev-medics4all-changeme
